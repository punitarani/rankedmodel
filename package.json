{
  "name": "rankedmodel",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts"
  ],
  "engines": {
    "node": ">=24",
    "bun": ">=1.3"
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "validate-data": "bun scripts/src/validate.ts",
    "ci": "bun run typecheck && bun run lint && bun run test && bun run build && bun run budgets",
    "dev": "bun run --filter '@rankedmodel/web' dev",
    "build": "bun run --filter '@rankedmodel/web' build",
    "derive": "bun scripts/src/derive.ts",
    "seed:local": "bun scripts/src/seed.ts --local",
    "publish-data:local": "bun scripts/src/publish-data.ts --local",
    "e2e": "bun run publish-data:local && bun run --filter '@rankedmodel/web' test:e2e",
    "budgets": "bun scripts/src/check-budgets.ts",
    "deploy:staging": "bun scripts/src/deploy.ts staging",
    "deploy:production": "bun scripts/src/deploy.ts production",
    "publish-data:remote": "bun scripts/src/publish-data.ts --remote"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "typescript": "^6.0.2"
  }
}
